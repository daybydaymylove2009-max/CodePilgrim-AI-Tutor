# CodePilgrim Backend Configuration

DATABASE_URL=postgresql+asyncpg://codepilgrim:codepilgrim@localhost:5432/codepilgrim
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

SANDBOX_DOCKER_IMAGE=codepilgrim-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MAX_MEMORY_MB=128

BKT_P_L0=0.2
BKT_P_G=0.25
BKT_P_S=0.15
BKT_P_T=0.1
BKT_MASTERY_THRESHOLD=0.85

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

DEBUG=true
